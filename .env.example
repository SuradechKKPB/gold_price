# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Supabase (gold project). URL is public; service-role key is secret (server/ETL only).
SUPABASE_URL=https://wdcwhvqjazyvuqzvczlv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# FRED (free key: https://fredaccount.stlouisfed.org/apikey)
FRED_API_KEY=

# LINE Messaging API channel access token (long-lived)
LINE_CHANNEL_ACCESS_TOKEN=

# Holding config — drives the headline THB figure
GOLD_GRAMS=700
GOLD_TYPE=bar          # bar = 96.5% ทองคำแท่ง (15.244 g/baht-weight)
BAR_SPREAD_THB=200     # modeled buy-in = sell - spread when live bid is unknown
